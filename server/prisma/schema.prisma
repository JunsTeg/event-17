generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Rsvp {
  id         Int      @id @default(autoincrement())
  nom        String
  prenom     String
  entreprise String
  fonction   String
  email      String   @unique
  telephone  String   @default("")
  statut     String   // "confirme" | "absent"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
