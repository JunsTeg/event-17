# URL publique de la plateforme (sans slash final)
# Utilisée pour les meta Open Graph et les liens de partage sur les réseaux sociaux
# Exemples :
#   https://rsvp.setect.cm
#   https://events.mon-domaine.com
#   http://localhost:5173   (développement local)
VITE_APP_URL=https://rsvp.setect.cm

# Nom affiché dans les meta (og:site_name)
VITE_APP_SITE_NAME=LANCEMENT OFFICIEL DESETECT 

# Compte Twitter/X de SETECT (optionnel, pour twitter:site)
VITE_TWITTER_HANDLE=@SETECT_CM
